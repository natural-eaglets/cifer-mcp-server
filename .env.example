# ============================================================
# CIFER Agent Skill — Environment Variables
# ============================================================

# REQUIRED — EVM private key of the agent wallet.
# This wallet must be the OWNER or DELEGATE of the secret.
# Never commit this file. Keep it in .gitignore.
CIFER_PK=0x_your_private_key_here

# REQUIRED — The CIFER secret ID this agent operates on.
# You get this from the CIFER Agent Console after creating a secret
# and delegating it to the agent's wallet address.
CIFER_SECRET_ID=31

# OPTIONAL — Override the Blackbox endpoint (defaults to Ternoa dev).
# CIFER_BLACKBOX_URL=https://cifer-blackbox.ternoa.dev:3010

# OPTIONAL — Override the Ternoa RPC endpoint.
# CIFER_RPC_URL=https://rpc-mainnet.zkevm.ternoa.network/

# OPTIONAL — Override the chain ID (default: 752025 = Ternoa mainnet).
# CIFER_CHAIN_ID=752025
